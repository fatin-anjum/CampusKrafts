# ─────────────────────────────────────────────────────────────
# CampusKrafts Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL) — matches docker-compose.yml defaults
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://campus:campus_pass@localhost:5432/campuskrafts?schema=public

# Redis (cache, rate-limit, leaderboard, queues)
REDIS_URL=redis://localhost:6379

# JWT — generate strong secrets: `openssl rand -hex 32`
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_REFRESH_TTL=2592000       # seconds (30 days)

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3 (object storage for videos, sheets, resources)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=campuskrafts-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SIGNED_URL_TTL=900

# LiveKit (built-in live classroom) — optional for local dev
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Payment gateways (use sandbox creds in dev). Webhooks verify signatures.
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_SANDBOX=true
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_FAIL_URL=http://localhost:3000/payment/fail

# The flagship Crash Course (seeded). Price in BDT.
CRASH_COURSE_PRICE_BDT=2500

# Default admin (created by seed) — change before production!
ADMIN_EMAIL=admin@campuskrafts.com
ADMIN_PASSWORD=Admin@12345
